<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- ── ESTIMATION FORM ───────────────────────────────────────────────── -->
    <record id="view_contract_estimation_form" model="ir.ui.view">
        <field name="name">setraco.contract.estimation.form</field>
        <field name="model">setraco.contract.estimation</field>
        <field name="arch" type="xml">
            <form string="Contract Estimation">
                <header>
                    <button name="action_submit_for_md" string="Submit for MD Review"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_md_approve" string="MD Approve"
                            type="object" class="btn-success"
                            groups="contract_management.group_contract_md"
                            invisible="state != 'reviewed'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,reviewed,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="tender_id"/>
                            <field name="client_id"/>
                        </group>
                        <group>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="markup_percent" widget="percentage"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- BOQ Tab -->
                        <page string="Bill of Quantities (BOQ)">
                            <field name="boq_line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="item_code"/>
                                    <field name="description"/>
                                    <field name="unit"/>
                                    <field name="quantity"/>
                                    <field name="unit_rate"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="source"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_boq" widget="monetary" readonly="1"
                                    class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>

                        <!-- Labour Tab -->
                        <page string="Labour Costs">
                            <field name="labour_line_ids">
                                <tree editable="bottom">
                                    <field name="role"/>
                                    <field name="grade"/>
                                    <field name="quantity"/>
                                    <field name="daily_rate"/>
                                    <field name="duration_days"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_labour" widget="monetary" readonly="1"
                                    class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>

                        <!-- Equipment Tab -->
                        <page string="Equipment / Plant Rates">
                            <field name="equipment_line_ids">
                                <tree editable="bottom">
                                    <field name="equipment_type"/>
                                    <field name="quantity"/>
                                    <field name="daily_rate"/>
                                    <field name="duration_days"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_equipment" widget="monetary" readonly="1"
                                    class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>

                        <!-- Operational Tab -->
                        <page string="Operational / Indirect Costs">
                            <field name="operational_line_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="cost_category"/>
                                    <field name="amount"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_operational" widget="monetary" readonly="1"
                                    class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>

                        <!-- Summary Tab -->
                        <page string="Cost Summary">
                            <group string="Cost Breakdown">
                                <group>
                                    <field name="total_boq" widget="monetary" readonly="1"/>
                                    <field name="total_labour" widget="monetary" readonly="1"/>
                                    <field name="total_equipment" widget="monetary" readonly="1"/>
                                    <field name="total_dry_cost" widget="monetary" readonly="1"/>
                                </group>
                                <group>
                                    <field name="total_operational" widget="monetary" readonly="1"/>
                                    <field name="total_selling_cost" widget="monetary" readonly="1"/>
                                    <field name="grand_total" widget="monetary" readonly="1"/>
                                    <field name="markup_percent" widget="percentage"/>
                                    <field name="tender_price" widget="monetary" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Notes">
                            <field name="notes" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── ESTIMATION TREE ───────────────────────────────────────────────── -->
    <record id="view_contract_estimation_tree" model="ir.ui.view">
        <field name="name">setraco.contract.estimation.tree</field>
        <field name="model">setraco.contract.estimation</field>
        <field name="arch" type="xml">
            <tree string="Estimations">
                <field name="name"/>
                <field name="tender_id"/>
                <field name="client_id"/>
                <field name="total_dry_cost" widget="monetary"/>
                <field name="total_selling_cost" widget="monetary"/>
                <field name="grand_total" widget="monetary"/>
                <field name="tender_price" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- ── ESTIMATION ACTION ─────────────────────────────────────────────── -->
    <record id="action_contract_estimation" model="ir.actions.act_window">
        <field name="name">Estimations</field>
        <field name="res_model">setraco.contract.estimation</field>
        <field name="view_mode">tree,form</field>
    </record>

    </data>
</odoo>