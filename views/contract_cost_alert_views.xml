<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="view_contract_cost_alert_form" model="ir.ui.view">
        <field name="name">setraco.contract.cost.alert.form</field>
        <field name="model">setraco.contract.cost.alert</field>
        <field name="arch" type="xml">
            <form string="Cost Alert">
                <header>
                    <button name="action_resolve" string="Mark Resolved"
                            type="object" class="btn-success"
                            invisible="state not in ('active','triggered')"/>
                    <button name="action_dismiss" string="Dismiss"
                            type="object" invisible="state not in ('active','triggered')"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="active,triggered,resolved"/>
                </header>
                <sheet>
                    <div class="alert alert-danger" role="alert"
                        invisible="state != 'triggered'">
                        🚨 This alert has been triggered — action required!
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Alert Details">
                            <field name="agreement_id"/>
                            <field name="alert_type"/>
                            <field name="date_triggered"/>
                        </group>
                        <group string="Cost Metrics">
                            <field name="budget_amount" widget="monetary"/>
                            <field name="actual_amount" widget="monetary"/>
                            <field name="usage_percent" widget="percentage" readonly="1"/>
                            <field name="threshold_percent" widget="percentage"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <group string="Resolution" invisible="state not in ('resolved','dismissed')">
                        <field name="resolved_by_id" widget="many2one_avatar_user"/>
                        <field name="resolution_notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_contract_cost_alert_tree" model="ir.ui.view">
        <field name="name">setraco.contract.cost.alert.tree</field>
        <field name="model">setraco.contract.cost.alert</field>
        <field name="arch" type="xml">
            <tree string="Cost Alerts"
                decoration-danger="state=='triggered'"
                decoration-muted="state in ('resolved','dismissed')">
                <field name="name"/>
                <field name="agreement_id"/>
                <field name="alert_type"/>
                <field name="budget_amount" widget="monetary"/>
                <field name="actual_amount" widget="monetary"/>
                <field name="usage_percent" widget="percentage"/>
                <field name="threshold_percent" widget="percentage"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="date_triggered"/>
                <field name="state" widget="badge"
                    decoration-danger="state=='triggered'"
                    decoration-success="state=='resolved'"/>
            </tree>
        </field>
    </record>

    <record id="action_contract_cost_alert" model="ir.actions.act_window">
        <field name="name">Cost Alerts</field>
        <field name="res_model">setraco.contract.cost.alert</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state','=','triggered')]</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    </data>
</odoo>