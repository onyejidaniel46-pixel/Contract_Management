<?xml version="1.0" encoding="UTF-8"?>
    <odoo>
        <data>

        <!--- REPORT ACTION BINDINGS
            These bind PDF reports to the Print menu on each form.-->

        <!-- Tender Document PDF -->
        <record id="action_report_tender_document" model="ir.actions.report">
        <field name="name">Tender Document</field>
        <field name="model">setraco.contract.tender</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contract_management.report_tender_document</field>
        <field name="report_file">contract_management.report_tender_document</field>
        <field name="binding_model_id" ref="model_setraco_contract_tender"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
        </record>

        <!-- Claims Certificate PDF -->
        <record id="action_report_claim_certificate" model="ir.actions.report">
        <field name="name">Claims Certificate</field>
        <field name="model">setraco.contract.claim</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contract_management.report_claim_certificate</field>
        <field name="report_file">contract_management.report_claim_certificate</field>
        <field name="binding_model_id" ref="model_setraco_contract_claim"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
        </record>

        <!-- Contract Agreement PDF -->
        <record id="action_report_contract_agreement" model="ir.actions.report">
        <field name="name">Contract Agreement</field>
        <field name="model">setraco.contract.agreement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contract_management.report_contract_agreement</field>
        <field name="report_file">contract_management.report_contract_agreement</field>
        <field name="binding_model_id" ref="model_setraco_contract_agreement"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
        </record>

        <!-- VOP Report PDF -->
        <record id="action_report_vop" model="ir.actions.report">
        <field name="name">Variation of Price (VOP) Report</field>
        <field name="model">setraco.contract.vop</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contract_management.report_vop</field>
        <field name="report_file">contract_management.report_vop</field>
        <field name="binding_model_id" ref="model_setraco_contract_vop"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
        </record>

        <!-- ══════════════════════════════════════════════════════════════
            REPORT TREE VIEWS  (menu → Reports sub-items)
        ══════════════════════════════════════════ -->

        <!-- Monthly Summary Report: Tree all claims grouped by contract -->
        <record id="view_report_monthly_claims_tree" model="ir.ui.view">
        <field name="name">setraco.contract.claim.report.tree</field>
        <field name="model">setraco.contract.claim</field>
        <field name="arch" type="xml">
            <tree string="Monthly Claims Report" create="false" delete="false"
                decoration-danger="is_overdue"
                decoration-success="state=='paid'">
            <field name="name" string="Certificate Ref"/>
            <field name="agreement_id" string="Contract"/>
            <field name="claim_number"/>
            <field name="claim_type"/>
            <field name="period_from"/>
            <field name="period_to"/>
            <field name="amount_claimed"  widget="monetary" sum="Total Claimed"/>
            <field name="amount_certified" widget="monetary" sum="Total Certified"/>
            <field name="amount_paid"     widget="monetary" sum="Total Paid"/>
            <field name="dry_cost_this_period"    widget="monetary" sum="Total Dry"/>
            <field name="selling_cost_this_period" widget="monetary" sum="Total Selling"/>
            <field name="currency_id" column_invisible="1"/>
            <field name="state" widget="badge"
                    decoration-success="state=='paid'"
                    decoration-warning="state=='submitted'"
                    decoration-danger="state in ('disputed',)"/>
            <field name="is_overdue" column_invisible="1"/>
            </tree>
        </field>
        </record>

        <!-- Monthly Summary Report: search view -->
        <record id="view_report_monthly_claims_search" model="ir.ui.view">
        <field name="name">setraco.contract.claim.report.search</field>
        <field name="model">setraco.contract.claim</field>
        <field name="arch" type="xml">
            <search string="Monthly Claims Report">
            <field name="agreement_id" string="Contract"/>
            <field name="client_id"/>
            <filter string="This Month" name="this_month"
                    domain="[('period_from','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d')),
                                ('period_to','&lt;=',  (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
            <filter string="Overdue" name="overdue" domain="[('is_overdue','=',True)]"/>
            <filter string="Unpaid"  name="unpaid"
                    domain="[('state','in',['submitted','certified'])]"/>
            <separator/>
            <group expand="1" string="Group By">
                <filter string="Contract"   name="grp_contract" context="{'group_by':'agreement_id'}"/>
                <filter string="Month"      name="grp_month"    context="{'group_by':'period_from:month'}"/>
                <filter string="Status"     name="grp_state"    context="{'group_by':'state'}"/>
            </group>
            </search>
        </field>
        </record>

        <!-- Monthly Summary Report: graph view -->
        <record id="view_report_monthly_claims_graph" model="ir.ui.view">
        <field name="name">setraco.contract.claim.report.graph</field>
        <field name="model">setraco.contract.claim</field>
        <field name="arch" type="xml">
            <graph string="Claims Overview" type="bar" stacked="1">
            <field name="agreement_id" type="row"/>
            <field name="amount_claimed"   type="measure"/>
            <field name="amount_certified" type="measure"/>
            <field name="amount_paid"      type="measure"/>
            </graph>
        </field>
        </record>

        <!-- Monthly Summary Report: pivot view -->
        <record id="view_report_monthly_claims_pivot" model="ir.ui.view">
        <field name="name">setraco.contract.claim.report.pivot</field>
        <field name="model">setraco.contract.claim</field>
        <field name="arch" type="xml">
            <pivot string="Claims Pivot">
            <field name="agreement_id"  type="row"/>
            <field name="period_from"   type="col" interval="month"/>
            <field name="amount_claimed"   type="measure"/>
            <field name="amount_certified" type="measure"/>
            <field name="amount_paid"      type="measure"/>
            <field name="dry_cost_this_period"    type="measure"/>
            <field name="selling_cost_this_period" type="measure"/>
            </pivot>
        </field>
        </record>

        <!-- Action: Monthly Claims Report -->
        <record id="action_report_monthly_claims" model="ir.actions.act_window">
    <field name="name">Monthly Claims Report</field>
    <field name="res_model">setraco.contract.claim</field>
    <field name="view_mode">tree,graph,pivot</field>
    <field name="view_ids" eval="[
        (5,0,0),
        (0,0,{'view_mode':'tree',  'view_id': ref('view_report_monthly_claims_tree')}),
        (0,0,{'view_mode':'graph', 'view_id': ref('view_report_monthly_claims_graph')}),
        (0,0,{'view_mode':'pivot', 'view_id': ref('view_report_monthly_claims_pivot')}),
    ]"/>
    <field name="search_view_id" ref="view_report_monthly_claims_search"/>
    <field name="context">{'search_default_grp_contract': 1}</field>
</record>


        <!-- VOP Report: tree + graph -->
        <record id="view_report_vop_tree" model="ir.ui.view">
        <field name="name">setraco.contract.vop.report.tree</field>
        <field name="model">setraco.contract.vop</field>
        <field name="arch" type="xml">
            <tree string="VOP Summary Report" create="false" delete="false"
                decoration-success="state=='boq_updated'"
                decoration-danger="state=='rejected'">
            <field name="name"/>
            <field name="agreement_id"/>
            <field name="vop_type"/>
            <field name="date_raised"/>
            <field name="original_amount" widget="monetary"/>
            <field name="vop_amount"      widget="monetary" sum="Total VOP"/>
            <field name="adjusted_contract_value" widget="monetary"/>
            <field name="currency_id" column_invisible="1"/>
            <field name="state" widget="badge"
                    decoration-success="state=='boq_updated'"
                    decoration-danger="state=='rejected'"/>
            </tree>
        </field>
        </record>

        <record id="view_report_vop_graph" model="ir.ui.view">
        <field name="name">setraco.contract.vop.report.graph</field>
        <field name="model">setraco.contract.vop</field>
        <field name="arch" type="xml">
            <graph string="VOP Impact" type="bar">
            <field name="agreement_id" type="row"/>
            <field name="vop_amount"   type="measure"/>
            </graph>
        </field>
        </record>

        <record id="action_report_vop_summary" model="ir.actions.act_window">
        <field name="name">VOP Summary Report</field>
        <field name="res_model">setraco.contract.vop</field>
        <field name="view_mode">tree,graph</field>
        <field name="view_ids" eval="[
            (5,0,0),
            (0,0,{'view_mode':'tree',  'view_id': ref('view_report_vop_tree')}),
            (0,0,{'view_mode':'graph', 'view_id': ref('view_report_vop_graph')}),
        ]"/>
        </record>

        <!-- Cost Alert Report -->
        <record id="action_report_cost_alerts" model="ir.actions.act_window">
        <field name="name">Cost Alert Report</field>
        <field name="res_model">setraco.contract.cost.alert</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state','=','triggered')]</field>
        <field name="context">{'search_default_triggered': 1}</field>
        </record>

    </data>
    </odoo>
