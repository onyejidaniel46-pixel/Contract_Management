<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Sequences ───────────────────────────────────────────────── -->

        <record id="seq_contract_tender" model="ir.sequence">
            <field name="name">Contract Tender</field>
            <field name="code">setraco.contract.tender</field>
            <field name="prefix">TND/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_contract_estimation" model="ir.sequence">
            <field name="name">Contract Estimation</field>
            <field name="code">setraco.contract.estimation</field>
            <field name="prefix">EST/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_contract_agreement" model="ir.sequence">
            <field name="name">Contract Agreement</field>
            <field name="code">setraco.contract.agreement</field>
            <field name="prefix">AGR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_contract_claim" model="ir.sequence">
            <field name="name">Claims Certificate</field>
            <field name="code">setraco.contract.claim</field>
            <field name="prefix">CLM/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_contract_vop" model="ir.sequence">
            <field name="name">Variation of Price</field>
            <field name="code">setraco.contract.vop</field>
            <field name="prefix">VOP/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_contract_cost_alert" model="ir.sequence">
            <field name="name">Cost Alert</field>
            <field name="code">setraco.contract.cost.alert</field>
            <field name="prefix">ALT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- ── Scheduled Action: Daily Cost Alert Check ─────────────────── -->
        <record id="ir_cron_contract_cost_alert" model="ir.cron">
            <field name="name">Setraco: Check Contract Cost Alerts</field>
            <field name="model_id" ref="model_setraco_contract_cost_alert"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_cost_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>


        <record id="seq_contract_loi" model="ir.sequence">
            <field name="name">Contract LOI</field>
            <field name="code">setraco.contract.loi</field>
            <field name="prefix">LOI/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_contract_advance_payment" model="ir.sequence">
            <field name="name">Contract Advance Payment</field>
            <field name="code">setraco.contract.advance.payment</field>
            <field name="prefix">ADV/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_contract_retc" model="ir.sequence">
            <field name="name">Contract RETC</field>
            <field name="code">setraco.contract.retc</field>
            <field name="prefix">RETC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_contract_boq" model="ir.sequence">
            <field name="name">Contract BOQ</field>
            <field name="code">setraco.contract.boq</field>
            <field name="prefix">BOQ/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_contract_handover" model="ir.sequence">
            <field name="name">Contract Handover</field>
            <field name="code">setraco.contract.handover</field>
            <field name="prefix">HO/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_contract_prequalification" model="ir.sequence">
            <field name="name">Contract Pre-Qualification</field>
            <field name="code">setraco.contract.prequalification</field>
            <field name="prefix">PQ/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_contract_data_request" model="ir.sequence">
            <field name="name">Contract Data Request</field>
            <field name="code">setraco.contract.data.request</field>
            <field name="prefix">DR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_contract_data_request_batch" model="ir.sequence">
            <field name="name">Contract Data Request Batch</field>
            <field name="code">setraco.contract.data.request.batch</field>
            <field name="prefix">DRB/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        
    </data>
</odoo>