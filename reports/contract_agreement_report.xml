<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_contract_agreement">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <style>
                            .report-header { display:flex; align-items:center; gap:12px; margin-block-end:16px; }
                            .report-header .logo { inline-size:30px; }
                            .report-header .logo img { inline-size:100%; block-size:auto; }
                            .report-header .company { font-size:12px; color:#894; }   
                            .watermark-img { position:fixed; inset-block-start:18%; inset-inline-start:10%; inline-size:80%; opacity:0.08; transform:rotate(-8deg); z-index:0; pointer-events:none; }
                            .page { position:relative; z-index:1; padding-block-start:28px; }
                            .report-table { border:none !important; inline-size:100%; border-collapse:collapse; }
                            .report-table th { inline-size:35%; white-space:nowrap; padding:10px 8px; border:none !important; border-block-end:1px solid #333; }
                            .report-table td { padding:10px 8px; border:none !important; border-block-end:1px solid #333; }
                            .report-table tr:last-child td { border-block-end:2px solid #333; }
                            .report-title { margin-block-start:0; margin-block-end:0.5rem; }
                        </style>
                        <div class="page">
                            <img class="watermark-img" src="/contract_management/static/src/img/setraco_logo.png"/> <!-- Watermark image is to be displayed in the background of the template -->
                            <div class="report-header">
                                <div class="logo">
                                    <img src="/contract_management/static/src/img/setraco_logo.png" alt="Setraco Logo"/>
                                </div>
                                <div class="company">
                                    <strong>SETRACO NIGERIA LIMITED</strong><br/>
                                    Setraco Building Plot 526, Shehu Yar'Adua Way<br/>
                                    Kado District <strong>Abuja</strong>, Nigeria<br/>
                                    Contact: +234 806 944 7441 | +234 805 222 5220
                                </div>
                            </div>
                            <h2 class="report-title" style="text-align:center;">Contract Agreement</h2>
                            <h3 style="text-align:center;margin-block-start:4px;">
                                <t t-esc="doc.name"/>
                            </h3>
                            <table class="table table-sm table-bordered report-table mt-4">
                                <tr>
                                    <th>Client</th>
                                    <td><t t-esc="doc.client_id.name or ''"/></td>
                                </tr>
                                <tr>
                                    <th>Source Tender</th>
                                    <td><t t-esc="doc.tender_id.name or ''"/></td>
                                </tr>
                                <tr>
                                    <th>Contract Value</th>
                                    <td>
                                        <t t-esc="doc.contract_value" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Date Signed</th>
                                    <td>
                                        <t t-esc="doc.date_signed" t-options='{"widget": "date"}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Commencement Date</th>
                                    <td>
                                        <t t-esc="doc.date_commencement" t-options='{"widget": "date"}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Completion Date</th>
                                    <td>
                                        <t t-esc="doc.date_completion" t-options='{"widget": "date"}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Site Location</th>
                                    <td><t t-esc="doc.site_location or ''"/></td>
                                </tr>
                                <tr>
                                    <th>Status</th>
                                    <td><t t-esc="doc.state"/></td>
                                </tr>
                            </table>
                            <div class="mt-4">
                                <h4>Notes</h4>
                                <div t-if="doc.notes">
                                    <t t-raw="doc.notes"/>
                                </div>
                                <p t-else="">No additional notes.</p>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
